{
  "name": "pi-quiz",
  "version": "0.1.0",
  "type": "module",
  "description": "Multiple-choice next-prompt quiz for pi — structured options instead of passive ghost text",
  "license": "MIT",
  "author": "Luke Nittmann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lnittman/pi-quiz.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "prompt-quiz",
    "multiple-choice",
    "developer-tools",
    "coding-agent"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  }
}
